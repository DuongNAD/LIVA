{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@skills/*": ["./src/skills/*"],
      "@utils/*": ["./src/utils/*"],
      "@core/*": ["./src/core/*"],
      "@memory/*": ["./src/memory/*"],
      "@security/*": ["./src/security/*"],
      "@mcp/*": ["./src/mcp/*"],
      "@services/*": ["./src/services/*"],
      "@evolution/*": ["./src/evolution/*"],
      "@sandbox/*": ["./src/sandbox/*"],
      "@deployment/*": ["./src/deployment/*"]
    }
  },
  "include": ["src/**/*"]
}