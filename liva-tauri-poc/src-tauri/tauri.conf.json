{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LIVA",
  "version": "25.0.0",
  "identifier": "com.liva.cognitive-os",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../liva-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "widget",
        "title": "LIVA Widget",
        "url": "/widget.html",
        "width": 400,
        "height": 700,
        "x": 1500,
        "y": 300,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false
      },
      {
        "label": "dashboard",
        "title": "LIVA Dashboard",
        "url": "/dashboard.html",
        "width": 1200,
        "height": 800,
        "center": true,
        "transparent": false,
        "decorations": false,
        "alwaysOnTop": false,
        "visible": true,
        "resizable": true,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
