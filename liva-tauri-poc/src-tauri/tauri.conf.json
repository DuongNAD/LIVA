{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "liva-tauri-poc",
  "version": "0.1.0",
  "identifier": "com.admin.liva-tauri-poc",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../liva-ui",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build --prefix ../liva-ui",
    "frontendDist": "../liva-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "liva-tauri-poc",
        "width": 800,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
