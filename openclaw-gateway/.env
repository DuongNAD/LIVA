# Lựa chọn nhà cung cấp (AI_PROVIDER có thể là 'local' hoặc 'openai')
AI_PROVIDER=openai

# Khóa bảo mật nếu dùng Cloud API (Điền khóa thật của Anh vào đây)
OPENAI_API_KEY=sk-abc123xyz...

# Tên mô hình đám mây muốn sử dụng
CLOUD_MODEL_NAME=gpt-4o-mini

# Tên mô hình chạy cục bộ
LOCAL_MODEL_NAME=Sentinel-Llama3-8B