# ═══════════════════════════════════════════════════
#  LIVA System — Unified Environment Configuration Template
#  Workspace Level | Version: v25.0
# ═══════════════════════════════════════════════════

# ─── 1. AI Provider Mode ────────────────────────────
# "local" = Local GGUF via llama-server / Native Engine (gRPC)
# "cloud" = Cloud API (OpenAI/Gemini compatible)
# "hybrid" = Local for chat, cloud for complex reasoning
AI_PROVIDER=local

# ─── 2. Local Model Configuration ───────────────────
# Directory where GGUF model files are stored
AI_MODELS_DIR=E:\AI_Models
ROUTER_MODEL_NAME=gemma-4-E4B-it-Q6_K.gguf
EXPERT_MODEL_NAME=gemma-4-26B-A4B-it-UD-Q6_K.gguf

# ─── 3. Native gRPC Engine ──────────────────────────
# "true" = Use NativeIPCClient (gRPC port 8100, zero HTTP overhead)
# "false" = Use OpenAI HTTP client (port 8000, legacy)
LIVA_USE_NATIVE=true

# Native engine hardware/concurrency tuning parameters
NATIVE_N_CTX=8192
NATIVE_N_GPU_LAYERS=-1
NATIVE_TEMPERATURE=0.7
NATIVE_N_BATCH=2048
NATIVE_N_THREADS=4

# ─── 4. Cloud API Configuration ─────────────────────
# (Required when AI_PROVIDER=cloud or AI_PROVIDER=hybrid)
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_API_KEY=your-api-key-here
AI_MODEL=gemini-2.5-flash

# ─── 5. Security & Encryption ───────────────────────
# 32-byte AES-256 key for central EncryptionEngine (Mandatory)
LIVA_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ─── 6. Network & Ports (Port Registry) ─────────────
# Port allocations for LIVA microservices
STT_PORT=8101          # Whisper STT REST server
NATIVE_AI_PORT=8100    # Native Python gRPC Inference Engine
TTS_PORT=8002          # Voice Engine WS/HTTP server
GATEWAY_PORT=8082      # Gateway WebSocket interface
VITE_DEV_PORT=5173     # Vite frontend dev server
LLM_PORT=8000          # Local llama-server HTTP interface

# ─── 7. STT & Voice Settings ────────────────────────
# STT (Whisper) endpoints and routing
WHISPER_URL=http://127.0.0.1:8101/v1/audio/transcriptions
WHISPER_MODEL=small

# Cloud STT for Local LLM mode to save GPU VRAM
# WHISPER_CLOUD_URL=https://api.groq.com/openai/v1/audio/transcriptions

# ─── 8. Social & Messaging Integrations ────────────
# Zalo OA settings
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_OA_ACCESS_TOKEN=
ZALO_USER_ID=

# Remote Control Hub (Telegram bot integration)
REMOTE_CONTROL_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_IDS=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_ID=

# ─── 9. Email Client (IMAP) ─────────────────────────
# Email monitor daemon settings (Gmail requires App Password)
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=
EMAIL_PASS=

# ─── 10. System & Telemetry ─────────────────────────
LIVA_GEOLOCATION_ENABLED=true
