
# ==========================================
# CẤU HÌNH AI PROVIDER & MODEL
# ==========================================

# 1. Chọn phương thức chạy / Nhà cung cấp (Provider)
# - Dùng API    : AI_PROVIDER=openai (hoặc gemini, anthropic... tùy code của bạn hỗ trợ)
# - Dùng Local  : AI_PROVIDER=local  (chạy mô hình trên máy tính cá nhân bằng Ollama/LMStudio/...)
AI_PROVIDER=local

# 2. Khóa API (API Key)
# Bắt buộc nếu bạn dùng Cloud API. 
# Hiện tại key của bạn trông giống Google Gemini API Key.
