{
  "name": "eprojectlivaliva-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "desktop": "electron electron.cjs",
    "desktop:watch": "electronmon . --watch electron.cjs --watch preload.cjs --watch src --watch public --watch dashboard.html --watch widget.html",
    "desktop:dev": "concurrently -k \"npm run dev\" \"npm run desktop:watch\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@pixiv/three-vrm": "^3.5.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "onnxruntime-web": "1.17",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "three": "^0.184.0",
    "unocss": "^66.6.8",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.6",
    "wait-on": "^9.0.10"
  }
}
