
# ==========================================
# CẤU HÌNH AI PROVIDER & MODEL
# ==========================================

# 1. Chọn phương thức chạy / Nhà cung cấp (Provider)
# - Dùng API    : AI_PROVIDER=cloud
# - Dùng Local  : AI_PROVIDER=local
AI_PROVIDER=local

# 2. Khóa API (API Key) & URL (chỉ cần khi AI_PROVIDER=cloud)
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# 3. Tên mô hình chạy Local (Multi-Agent Cascade Routing)
# Thư mục chứa model cục bộ
AI_MODELS_DIR="E:\AI_Models"

# Mô hình nhẹ để chat nhanh (Router)
ROUTER_MODEL_NAME=gemma-4-E4B-it-Q4_K_M.gguf
# Mô hình chuyên gia để xử lý task nặng (Expert Worker)
EXPERT_MODEL_NAME=Qwen2.5-Coder-14B-Instruct-Q4_K_M.gguf

# ==========================================
# CẤU HÌNH EMAIL (IMAP)
# ==========================================
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=
EMAIL_PASS=

# ==========================================
# CẤU HÌNH ZALO (BOT API)
# ==========================================
